# Database
DATABASE_URL="postgresql://shopnest:shopnest@localhost:5432/shopnest_dev"

# Server
PORT=3001
NODE_ENV=development

# Frontend URL (used for CORS and Origin validation)
WEB_URL=http://localhost:3000

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access-secret-64-bytes-hex
JWT_REFRESH_SECRET=change-me-refresh-secret-64-bytes-hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Grace period for concurrent refresh (milliseconds)
REFRESH_GRACE_PERIOD_MS=30000

# Cart limit per product
CART_MAX_QTY_PER_PRODUCT=10
